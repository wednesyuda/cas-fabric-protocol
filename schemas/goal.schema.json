{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cas-fabric-protocol/schemas/goal.schema.json",
  "title": "Goal",
  "description": "Persistent objective tracked by the Goal System.",
  "type": "object",
  "properties": {
    "goal_id": { "type": "string" },
    "intent": { "type": "string" },
    "required_skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "state": {
      "type": "string",
      "enum": ["created", "broadcast", "assigned", "executing", "completed", "failed", "suspended"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "history": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "required": ["goal_id", "intent", "required_skills", "state"]
}
